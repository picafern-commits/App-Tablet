  M611: { next: "M76", slot: "homeTeam" },
  M612: { next: "M76", slot: "awayTeam" },
  M613: { next: "M77", slot: "homeTeam" },
  M614: { next: "M77", slot: "awayTeam" },
  M615: { next: "M78", slot: "homeTeam" },
  M616: { next: "M78", slot: "awayTeam" },

  M71: { next: "M81", slot: "homeTeam" },
