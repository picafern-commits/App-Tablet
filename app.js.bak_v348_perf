}

function pushChatMobileHistory() {
  if (!isMobileChatPageMode()) return;
  if (window.location.hash === "#chat") return;

  try {
    history.pushState({ chatOpen: true }, "", "#chat");
  } catch {}
}

function closeChatFromHistorySafe() {
