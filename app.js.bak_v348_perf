    const remoteBets = normalizeBets(snap.docs.map(item => ({ id: item.id, ...item.data() })));
    const byId = new Map(remoteBets.map(bet => [bet.id, bet]));

    localPending.forEach((bet, id) => byId.set(id, bet));
    deleted.forEach(id => byId.delete(id));
