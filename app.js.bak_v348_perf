  if (currentProfile?.active !== false) {
    const clean = String(currentProfile?.name || currentProfile?.email || currentUser?.email || "").trim();
    if (clean) names.add(clean.toLowerCase());
  }
  return names.size || 18;
}


function isMobileChatPageMode() {
