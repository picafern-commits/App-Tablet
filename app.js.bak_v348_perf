  sf: ["M91","M92"],
  final: ["M101"]
};

const CLEAN_KNOCKOUT_NEXT_V338 = {
  M61: { next: "M71", slot: "homeTeam" },
  M62: { next: "M71", slot: "awayTeam" },
  M63: { next: "M72", slot: "homeTeam" },
