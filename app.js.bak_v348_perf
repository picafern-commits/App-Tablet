      await saveSettingsFastToFirebase("confirmar leitura aviso obrigatório v295");
    } else {
      saveLocalData?.("confirmar leitura aviso obrigatório v295");
      scheduleFullSync?.("confirmar leitura aviso obrigatório v295", 300);
