  document.getElementById("mandatoryNoticeModalV295")?.classList.add("hidden");
  document.body.classList.remove("mandatory-notice-open-v295");
  try { renderMandatoryNoticeAdminPanelV295?.(); } catch {}
  toast?.("Confirmação registada.");
