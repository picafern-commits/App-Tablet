      <div id="chatPanel" class="chat-panel hidden">
        <div class="chat-header">
          <div>
            <strong>Chat Mundial</strong>
            <span id="chatSubtitle">Conversa geral dos users</span>
          </div>
          <button id="chatCloseBtn" class="chat-close-btn" type="button" aria-label="Fechar chat" onclick="return window.closeChatMobileClean(event)">x</button>
        </div>

        <div class="chat-room-switch">
          <button id="chatGeneralTab" class="chat-room-btn active" type="button" data-chat-room="general">Geral</button>
          <button id="chatAdminTab" class="chat-room-btn admin-chat-tab hidden" type="button" data-chat-room="admin">Admin</button>
        </div>

        <div class="chat-search-wrap">
          <input id="chatSearchInput" type="search" autocomplete="off" placeholder="Pesquisar no chat..." />
        </div>

        <div id="chatPinnedBox" class="chat-pinned-box hidden"></div>
        <div id="chatTypingBox" class="chat-typing-box hidden"></div>

        <div id="chatMessages" class="chat-messages">
          <div class="empty small-empty">A carregar chat...</div>
        </div>

        <div id="chatReplyPreview" class="chat-reply-preview hidden">
          <div>
            <span>A responder a <strong id="chatReplyName"></strong></span>
            <p id="chatReplyText"></p>
          </div>
          <button id="chatReplyCancelBtn" type="button" aria-label="Cancelar resposta">x</button>
        </div>

        <form id="chatForm" class="chat-form">
          <button id="chatImageBtn" class="chat-attach-btn" type="button" aria-label="Enviar imagem">+</button>
          <input id="chatImageInput" type="file" accept="image/*" class="hidden" />
          <input id="chatInput" type="text" maxlength="500" autocomplete="off" placeholder="Mensagem" />
          <button id="chatSendBtn" class="primary" type="submit" aria-label="Enviar mensagem">Enviar</button>
        </form>
      </div>
      <div id="chatActionMenu" class="chat-action-menu hidden">
        <button id="chatActionReplyBtn" type="button">Responder</button>
        <button id="chatActionPinBtn" type="button">Fixar</button>
        <button id="chatActionDeleteBtn" type="button">Apagar</button>
        <div class="chat-reaction-bar" id="chatReactionBar">
          <button type="button" data-chat-reaction="Haha">Haha</button>
          <button type="button" data-chat-reaction="Golo">Golo</button>
          <button type="button" data-chat-reaction="Taca">Taca</button>
          <button type="button" data-chat-reaction="Forca">Forca</button>
          <button type="button" data-chat-reaction="Olhos">Olhos</button>
          <button type="button" data-chat-reaction="Ok">Ok</button>
        </div>
      </div>
      <div id="chatImageViewer" class="chat-image-viewer hidden" aria-modal="true" role="dialog">
        <button id="chatImageViewerClose" class="chat-image-viewer-close" type="button" aria-label="Fechar imagem">x</button>
        <img id="chatImageViewerImg" alt="Imagem do chat" />
      </div>
</body>
</html>
